# --- Telegram ---
# Токен бота от @BotFather (для локальной разработки заведи отдельного тест-бота)
TELEGRAM_BOT_TOKEN=

# --- База данных ---
# По умолчанию SQLite в ./data. Переезд на Postgres = смена только этой строки.
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Часовой пояс по умолчанию для новых участников / планировщика
DEFAULT_TIMEZONE=Europe/Tallinn

# --- LLM (нужно с этапа 4) ---
LLM_PROVIDER=gemini            # gemini | openai | anthropic | openrouter
LLM_MODEL=
LLM_API_KEY=
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_API_KEY=

# --- Голос → текст (нужно с этапа 5) ---
WHISPER_MODE=local             # local | api
WHISPER_CPP_PATH=
WHISPER_MODEL_PATH=
OPENAI_API_KEY=                # если WHISPER_MODE=api

# --- Google Sheets (нужно с этапа 6) ---
GOOGLE_SERVICE_ACCOUNT_JSON=
